# vim:set et ts=2 sw=2 sts=2 ft=sh:

# docker
#export DOCKER_CONTENT_TRUST=1

docker_rm() {
  local id=$(docker ps -a | tail -n +2 | fzf | sed -E -e 's/ +/ /g' | cut -d' ' -f1)
  if [ ! -z "$id" ]; then
    docker rm $id
  fi
}

docker_rmi() {
  local id=$(docker images | tail -n +2 | fzf | sed -E -e 's/ +/ /g' | cut -d' ' -f3)
  if [ ! -z "$id" ]; then
    docker rmi $id
  fi
}

docker_rm_exited() {
  docker rm $(docker ps -aqf "status=exited")
}

docker_rmi_dangling() {
  docker rmi $(docker images -aqf "dangling=true")
}

alias di='docker images'
alias dp='docker ps'
alias da='docker ps -a'
alias dx='docker exec'
alias dr='docker_rm'
alias dri='docker_rmi'
alias dc='docker-compose'
